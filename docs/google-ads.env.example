# OMO-2557 — Google Ads API 자격증명 (예시)
# 실제 값은 repo에 커밋하지 말 것. 아래 "실제 파일 위치"에 저장한다.
#
# 실제 파일 위치(에이전트가 읽는 기본 경로):
#   /Users/william/.paperclip/instances/default/workspaces/2bb373e7-cea0-47a6-9a24-b51ebfa59755/secrets/google-ads.env
#
# 채우는 방법은 docs/OMO-2557-google-ads-api-setup.md 참고.

# Google Ads API 개발자 토큰 (MCC → Tools → API Center)
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth 2.0 클라이언트 (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 위 클라이언트로 adwords 스코프 동의 후 발급된 refresh token (OAuth Playground 등)
GOOGLE_OAUTH_REFRESH_TOKEN=

# 전환을 생성할 Google Ads 계정 ID (10자리, 하이픈 제거)
GOOGLE_ADS_CUSTOMER_ID=

# (선택) 위 계정이 MCC 하위면 MCC(관리자) 계정 ID. 단일 계정이면 비워둠.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
