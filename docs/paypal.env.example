# OMO-2908 / OMO-2909 — PayPal 결제 자격증명 (예시)
# 실제 값은 repo에 커밋하지 말 것. Vercel Production env 에 주입한다.
#
# 발급처: https://developer.paypal.com → Apps & Credentials
#   - Sandbox 탭: 테스트용 Client ID/Secret
#   - Live 탭:    실결제용 Client ID/Secret (Create App 후 발급)

# REST 앱 자격증명 (서버 사이드)
# PAYPAL_CLIENT_ID 미설정 시 코드가 NEXT_PUBLIC_PAYPAL_CLIENT_ID 로 폴백한다.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# 브라우저 SDK 로드용 (공개값). 위 Client ID 와 동일.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# 결제 모드 스위치
#   샌드박스: https://api-m.sandbox.paypal.com
#   라이브:   https://api-m.paypal.com
# 빈 문자열("")이면 코드가 샌드박스로 폴백한다(OMO-2908 안전망).
PAYPAL_API_URL=https://api-m.paypal.com

# 카드 명세서 표기명(soft descriptor). PayPal 이 'PAYPAL *' 접두사를 자동으로 붙인다.
# 최대 22자, 영문/숫자/공백만(코드가 자동 정제). 미설정 시 PayPal 계정 사업자명 사용.
PAYPAL_SOFT_DESCRIPTOR=PROCARDCRAFTERS

# OMO-2909 서버 웹훅 서명검증용. PayPal Developer Dashboard 에서
# 웹훅(엔드포인트: https://procardcrafters.com/api/paypal/webhook)을 등록하면 발급된다.
# 구독 이벤트: PAYMENT.CAPTURE.COMPLETED, CHECKOUT.ORDER.APPROVED.
# 미설정 시 웹훅 라우트가 위조 차단을 위해 500 으로 거부한다.
PAYPAL_WEBHOOK_ID=
