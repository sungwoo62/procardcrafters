# 회사 공통 포커싱 / North Star (OMO-2582, 보드 지시 — 6개 서비스 공통, 변경 금지)
# 모든 자동화·성과측정·마케팅 최적화 의사결정은 이 북극성에 정렬한다.
NEXT_PUBLIC_NORTH_STAR=조직의 성장 + 고객 만족도 향상
NEXT_PUBLIC_NORTH_STAR_PILLARS=업무 풀 자동화,성과측정 및 평가,마케팅 성과측정 및 평가와 개선

# 공유 Supabase 프로젝트 (ilcfemvqommqyoohfoxw)
NEXT_PUBLIC_SUPABASE_URL=https://ilcfemvqommqyoohfoxw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (테스트 모드: sk_test_... / 라이브 모드: sk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Stripe 대시보드 > Developers > Webhooks > 해당 엔드포인트의 Signing secret
STRIPE_WEBHOOK_SECRET=

# 사이트 URL (로컬: http://localhost:3000 / 프로덕션: https://procardcrafters.com)
NEXT_PUBLIC_SITE_URL=https://procardcrafters.com

# 관리자 대시보드 (/admin/orders 접근 시 사용)
ADMIN_SECRET=

# AI 견적 챗봇 (Anthropic — https://console.anthropic.com/settings/keys)
# 필수: 미설정 시 /api/chat 가 503(과거 무가드 시 500) → 챗봇 전체 무응답.
# Vercel Production env에도 반드시 동일 키 주입할 것. (OMO-2703)
ANTHROPIC_API_KEY=

# 이메일 알림 (Resend — https://resend.com)
RESEND_API_KEY=

# 관리자 알림 이메일 (주문 접수/상태 변경 시 알림 수신)
ADMIN_NOTIFICATION_EMAIL=admin@procardcrafters.com

# PayPal (Sandbox: https://developer.paypal.com / Live: https://paypal.com)
# Sandbox 테스트: PAYPAL_API_URL 생략 시 자동으로 sandbox 사용
#
# 두 가지 환경변수 모두 같은 Client ID를 넣으세요:
#  - NEXT_PUBLIC_PAYPAL_CLIENT_ID : 브라우저 SDK (`<PayPalScriptProvider>`) 에서 사용
#  - PAYPAL_CLIENT_ID             : 서버 OAuth (lib/paypal.ts) 에서 사용
# (서버는 NEXT_PUBLIC_* 도 fallback 으로 읽기 때문에 둘 다 채우는 게 안전합니다)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# 라이브 전환 시 아래 주석 해제 (기본값: sandbox)
# PAYPAL_API_URL=https://api-m.paypal.com

# GA4 (Google Analytics — https://analytics.google.com)
# 형식: G-XXXXXXXXXX (클라이언트측 세션 수집용)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# GA4 Data API — CVR(전환율) 서버 조인용 (OMO-2593). 세션수를 서버에서 끌어와
# print_orders 주문수와 조인해 CVR을 산출한다. 측정ID(G-)와 별개로 아래 2개 필요.
#   GA4_PROPERTY_ID: 숫자 속성ID (GA4 관리 > 속성 설정 > 속성 ID)
#   GOOGLE_APPLICATION_CREDENTIALS: 서비스계정 JSON 경로. 해당 서비스계정 이메일을
#     GA4 속성에 '뷰어'로 추가해야 함(보드/오너 액션). 미설정 시 CVR 분자=데이터 부족.
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Meta Pixel (Facebook Ads — https://business.facebook.com/events_manager)
# 형식: 숫자 15~16자리
NEXT_PUBLIC_META_PIXEL_ID=

# FedEx Rate API (계약: 2520066223-100, account 210839884)
# Developer Portal: https://developer.fedex.com → Create production credentials
# 자격 미설정 시 DB 시드 요금표로 자동 fallback
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=210839884
# FEDEX_API_BASE=https://apis-sandbox.fedex.com  # 샌드박스 테스트 시 활성화

# printcity(dtp21/iamdesign) 발주 계정 — OMO-3414. 값은 .env.local 에만(gitignored).
PRINTCITY_USERNAME=
PRINTCITY_PASSWORD=
PRINTCITY_LOGIN_URL=https://printcity.co.kr/

# OMO-3482 (board 2026-06-18): 공급사=성원(swadpia) 확정. printcity 노출 경로
#   (/business-cards, /business-cards/[id], /reports/printcity-*)를 UI에서 전부 숨김.
#   기본값=숨김(env 미설정 시에도 숨김). 재노출 롤백은 PRINTCITY_HIDDEN=0.
# PRINTCITY_HIDDEN=0  # 0|false → printcity 라우트 재노출(롤백). unset|1|true → 숨김
