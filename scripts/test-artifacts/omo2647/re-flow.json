    "chgBakType": "function chgBakType(seq) {\n\n\t\tif ($('chk_is_bak').checked == true) {\n\t\t\tproduct1.ppBak(seq);\n\t\t}\n\n\t}",
    "chgTagongNum": "function chgTagongNum() {\n\t\tif ($('chk_is_tagong').checked == true) {\n\t\t\tproduct1.ppTagong();\n\t\t}\n\t}",
    "chgTagongSize": "function chgTagongSize() {\n\t\tif ($('chk_is_tagong').checked == true) {\n\t\t\tproduct1.ppTagong();\n\t\t}\n\t}",
    "addBak": "function addBak(seq) {\n\t\t$j('#pnl_bak' + seq).show();\n\t\t$j('#btn_add_bak' + seq).hide();\n\n\t\t//박 합계금액\n\t\tproduct1.setPPBakAmtSum();\n\t\tproduct1.calcuEstimate();\n\n\t}",
    "addAP": "function addAP(seq) {\n\t\t$j('#pnl_ap' + seq).show();\n\t\t$j('#btn_add_ap' + seq).hide();\n\n\t\t//박 합계금액\n\t\tproduct1.setPPApAmtSum();\n\t\tproduct1.calcuEstimate();\n\n\t}"
