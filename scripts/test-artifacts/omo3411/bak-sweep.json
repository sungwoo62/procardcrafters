    ],
    "chgBakSize": "function chgBakSize(seq) {\n\n\t\tbak_x_size = parseFloat($('bak_x_size_' + seq).value);\n\t\tbak_y_size = parseFloat($('bak_y_size_' + seq).value);\n\n\t\tif (bak_x_size < 0.1) {\n\t\t\talert('박 가로사이즈는 0보다 커야 합니다.');\n\t\t\t$('bak_x_size_' + seq).value = '0.1';\n\t\t\t$('bak_x_size_' + seq).focus();\n\t\t\t//return;\n\t\t} else if (bak_y_size < 0.1) {\n\t\t\talert('박 세로사이즈는 0보다 커야 합니다.');\n\t\t\t$('bak_y_size_' + seq).value = '0.1';\n\t\t\t$('bak_y_size_' + seq).focus();\n\t\t\t//return;\n\t\t}\n\n\t\tif ($('chk_is_bak').checked == true) {\n\t\t\tproduct1.ppBak(seq);\n\t\t}\n\n\t}",
    "chgBakSection": "function chgBakSection(seq) {\n\n\t\tif ($('chk_is_bak').checked == true) {\n\t\t\tproduct1.ppBak(seq);\n\t\t}\n\n\t}",
    "chgBakSide": "function chgBakSide(seq) {\n\n\t\tif ($('chk_is_bak').checked == true) {\n\t\t\tproduct1.ppBak(seq);\n\t\t}\n\n\t}",
    "chgBakType": "function chgBakType(seq) {\n\n\t\tif ($('chk_is_bak').checked == true) {\n\t\t\tproduct1.ppBak(seq);\n\t\t}\n\n\t}",
    "chgBakExistDongpan": "function chgBakExistDongpan(seq) {\r\n\r\n  var bak_exist_dongpan = $('bak_exist_dongpan_' + seq).value;\r\n  //console.info(bak_exist_dongpan);\r\n\r\n  var bak_exist_dongpan_arry = bak_exist_dongpan.split(\"^\");\r\n  var order_no = bak_exist_dongpan_arry[0];\r\n  var order_item_no = bak_exist_dongpan_arry[1];\r\n  var postpress_seq = bak_exist_dongpan_arry[2];\r\n  var x_size = bak_exist_dongpan_arry[3];\r\n  var y_size = bak_exist_dongpan_arry[4];\r\n  var bak_order_item_key = bak_exist_dongpan_arry[5];\r\n  var bak_no = bak_exist_dongpan_arry[6];//관리자페이지 셋팅값//순번\r\n\r\n  $('bak_x_size_' + seq).value = x_size;\r\n  $('bak_y_size_' + seq).value = y_size;\r\n  $('bak_order_item_key_' + seq).value = bak_order_item_key;\r\n  $('bak_no_' + seq).value = bak_no;\r\n\r\n  chgBakExistDongpanPrice(seq);\r\n}",
    "chgBakExistDongpanPrice": "function chgBakExistDongpanPrice(seq) {\n\n\t\tproduct1.ppBakExistDongpan(seq);\n\n\t}"
  },
